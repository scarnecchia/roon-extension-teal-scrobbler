# teal.fm Roon Scrobbler — environment configuration
# Copy to .env and fill in your values.
# These seed the initial settings; Roon UI settings override them.

# Bluesky handle (e.g. yourname.bsky.social)
TEAL_HANDLE=

# Bluesky app password (generate at Settings → App Passwords)
TEAL_APP_PASSWORD=

# Music service domain for play records (default: local)
# Examples: local, tidal.com, qobuz.com
TEAL_MUSIC_SERVICE_DOMAIN=local

# Comma-separated zone IDs to track (empty = all zones)
TEAL_ALLOWED_ZONE_IDS=
